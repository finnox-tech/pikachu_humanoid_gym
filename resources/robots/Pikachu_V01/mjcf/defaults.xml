<!-- defaults.xml -->
<mujoco>
    <!-- 皮卡丘主类 -->
    <default>
       <default class="pikachu">
            <geom rgba="1 1 0 1" friction="0.4" margin="0.001" condim="1"/>  <!-- 黄色 中等摩擦 扩展碰撞边界 碰撞维度 -->
            <!-- <joint damping="0.1" armature="0.001" frictionloss="0.2"/>       阻抗系数 转子惯量 静摩擦损失 -->

            <!-- 尾巴类 -->
            <default class="tail">
                <!-- 3507 -->
                <joint range="-1.05 1.05" 
                       damping="0.05" armature="0.001" frictionloss="0.01"/>
            </default>

            <!-- 手臂类 -->
            <default class="arm">
                <!-- 4340 -->
                <joint range="-3.14 -0.77"
                        damping="0.4" armature="0.001" frictionloss="0.01"/>
            </default>

            <!-- 腿部类 -->
            <default class="leg">

                <default class="hip1">
                    <!-- 4340 -->
                    <joint range="-0.7 2.7"
                           damping="0.4" armature="0.001" frictionloss="0.01"/>
                </default>

                <default class="hip2">
                    <!-- 4340 -->
                    <joint range="-0.122 0.139"
                           damping="0.4" armature="0.001" frictionloss="0.01"/>
                </default>

                <default class="hip3">
                    <!-- 4340 -->
                    <joint  range="-0.261 0.261"
                            damping="0.4" armature="0.001" frictionloss="0.01"/>

                </default>

                <default class="knee">
                    <!-- 4340 -->
                    <joint  range="0.04 2.44"
                            damping="0.4" armature="0.001" frictionloss="0.01"/>
                </default>

                <default class="ankle">
                    <!-- 4340 -->
                    <joint  range="-1.64 1.64"
                            damping="0.4" armature="0.001" frictionloss="0.01"/>
                </default>
            </default>
            
            <!-- 视觉类 -->
            <default class="visual">
            <geom contype="0" conaffinity="0" group="2"/>
            </default>

        </default>
    </default>

</mujoco>